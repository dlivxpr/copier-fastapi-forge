"""Project management CLI."""

[% if background_tasks == "taskiq" %]import subprocess

[% endif -%]
import click
import uvicorn
[% if database == "postgresql" %]from alembic.config import Config
[% endif %]from tabulate import tabulate

[% if database == "postgresql" %]from alembic import command
[% endif %]from app.main import app


@click.group()
@click.version_option(version="0.1.0", prog_name="[[ project_slug ]]")
def cli() -> None:
    """[[ project_name ]] management CLI."""


@cli.group("server")
def server_cli() -> None:
    """Server commands."""


@server_cli.command("run")
@click.option("--host", default="0.0.0.0", help="Host to bind to")
@click.option("--port", default=[[ backend_port ]], type=int, help="Port to bind to")
@click.option("--reload", is_flag=True, help="Enable auto-reload")
def server_run(host: str, port: int, reload: bool) -> None:
    """Run the development server."""
    uvicorn.run("app.main:app", host=host, port=port, reload=reload)


@server_cli.command("routes")
def server_routes() -> None:
    """Show all registered routes."""
    routes: list[list[str]] = []
    for route in app.routes:
        path = getattr(route, "path", None)
        if path is None:
            continue
        methods = getattr(route, "methods", set())
        for method in methods - {"HEAD", "OPTIONS"}:
            routes.append([method, path, getattr(route, "name", "-")])
    click.echo(tabulate(routes, headers=["Method", "Path", "Name"]))
[% if database == "postgresql" %]

@cli.group("db")
def db_cli() -> None:
    """Database commands."""


@db_cli.command("init")
def db_init() -> None:
    """Initialize the database by running all migrations."""
    click.echo("Initializing database...")
    command.upgrade(Config("alembic.ini"), "head")
    click.secho("Database initialized.", fg="green")


@db_cli.command("migrate")
@click.option("-m", "--message", required=True, help="Migration message")
def db_migrate(message: str) -> None:
    """Create a new migration."""
    command.revision(Config("alembic.ini"), message=message, autogenerate=True)
    click.secho(f"Migration created: {message}", fg="green")


@db_cli.command("upgrade")
@click.option("--revision", default="head", help="Revision to upgrade to")
def db_upgrade(revision: str) -> None:
    """Run database migrations."""
    command.upgrade(Config("alembic.ini"), revision)
    click.secho(f"Upgraded to: {revision}", fg="green")


@db_cli.command("downgrade")
@click.option("--revision", default="-1", help="Revision to downgrade to")
def db_downgrade(revision: str) -> None:
    """Roll back database migrations."""
    command.downgrade(Config("alembic.ini"), revision)
    click.secho(f"Downgraded to: {revision}", fg="green")


@db_cli.command("current")
def db_current() -> None:
    """Show the current migration revision."""
    command.current(Config("alembic.ini"))


@db_cli.command("history")
def db_history() -> None:
    """Show migration history."""
    command.history(Config("alembic.ini"))
[% endif %][% if background_tasks == "taskiq" %]

@cli.group("taskiq")
def taskiq_cli() -> None:
    """Taskiq process commands."""


@taskiq_cli.command("worker")
@click.option("--workers", default=2, type=int, help="Number of workers")
@click.option("--reload", is_flag=True, help="Enable auto-reload")
def taskiq_worker(workers: int, reload: bool) -> None:
    """Start the Taskiq worker."""
    command = [
        "taskiq",
        "worker",
        "app.worker.taskiq_app:broker",
        f"--workers={workers}",
    ]
    if reload:
        command.append("--reload")
    subprocess.run(command, check=True)


@taskiq_cli.command("scheduler")
def taskiq_scheduler() -> None:
    """Start the Taskiq scheduler."""
    subprocess.run(
        ["taskiq", "scheduler", "app.worker.taskiq_app:scheduler"],
        check=True,
    )
[% endif %]

if __name__ == "__main__":
    cli()
