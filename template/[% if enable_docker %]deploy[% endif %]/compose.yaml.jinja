services:
  app:
    build:
      context: ..
      dockerfile: deploy/Dockerfile
    environment:
      API_KEY: "${API_KEY:-[[ deployment_api_key ]]}"
[% if database == "postgresql" %]      DATABASE_URL: postgresql+asyncpg://postgres:postgres@postgres:5432/app
[% endif %][% if enable_redis %]      REDIS_HOST: redis
      REDIS_PORT: 6379
[% endif %][% if background_tasks == "taskiq" %]      TASKIQ_BROKER_URL: redis://redis:6379/1
      TASKIQ_RESULT_BACKEND_URL: redis://redis:6379/1
[% endif %][% if ai_framework == "pydantic_ai" %]      LLM_BASE_URL: "${LLM_BASE_URL:-https://api.example.com/v1}"
      LLM_API_KEY: "${LLM_API_KEY:-model-key-CHANGEME}"
      LLM_MODEL: "${LLM_MODEL:-model-name-CHANGEME}"
[% endif %][% if ai_framework == "pydantic_ai" and enable_logfire %]      LOGFIRE_TOKEN: "${LOGFIRE_TOKEN:-}"
[% endif %]    ports:
      - "8000:8000"
[% if database == "postgresql" or enable_redis or background_tasks == "taskiq" %]    depends_on:
[% if database == "postgresql" %]      migrate:
        condition: service_completed_successfully
[% endif %][% if enable_redis or background_tasks == "taskiq" %]      redis:
        condition: service_healthy
[% endif %][% endif %]    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health/ready')"]
      interval: 10s
      timeout: 3s
      retries: 5
[% if background_tasks == "taskiq" %]
  worker:
    build:
      context: ..
      dockerfile: deploy/Dockerfile
    command: ["uv", "run", "--no-sync", "taskiq", "worker", "app.worker.taskiq_app:broker"]
    environment:
      TASKIQ_BROKER_URL: redis://redis:6379/1
      TASKIQ_RESULT_BACKEND_URL: redis://redis:6379/1
    depends_on:
      redis:
        condition: service_healthy

  scheduler:
    build:
      context: ..
      dockerfile: deploy/Dockerfile
    command: ["uv", "run", "--no-sync", "taskiq", "scheduler", "app.worker.taskiq_app:scheduler"]
    environment:
      TASKIQ_BROKER_URL: redis://redis:6379/1
      TASKIQ_RESULT_BACKEND_URL: redis://redis:6379/1
    depends_on:
      redis:
        condition: service_healthy
[% endif %][% if database == "postgresql" %]
  migrate:
    build:
      context: ..
      dockerfile: deploy/Dockerfile
    command: ["uv", "run", "--no-sync", "alembic", "upgrade", "head"]
    environment:
      DATABASE_URL: postgresql+asyncpg://postgres:postgres@postgres:5432/app
    depends_on:
      postgres:
        condition: service_healthy

  postgres:
    image: postgres:17-alpine
    environment:
      POSTGRES_DB: app
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d app"]
      interval: 2s
      timeout: 3s
      retries: 15
    volumes:
      - postgres-data:/var/lib/postgresql/data
[% endif %][% if enable_redis or background_tasks == "taskiq" %]
  redis:
    image: redis:8-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 2s
      timeout: 3s
      retries: 15
    volumes:
      - redis-data:/data
[% endif %][% if database == "postgresql" or enable_redis or background_tasks == "taskiq" %]
volumes:
[% if database == "postgresql" %]  postgres-data:
[% endif %][% if enable_redis or background_tasks == "taskiq" %]  redis-data:
[% endif %][% endif %]