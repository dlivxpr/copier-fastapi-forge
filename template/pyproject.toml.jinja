[project]
name = "[[ module_name ]]"
version = "0.1.0"
description = "[[ project_description ]]"
readme = "README.md"
requires-python = ">=[[ python_version ]]"
dependencies = [
[% if agent_capability == "pydantic-ai" %]    "fastapi[standard]>=0.135.0",
[% else %]    "fastapi[standard]>=0.115.0",
[% endif %]
    "pydantic-settings>=2.7.0",
[% if background_tasks == "taskiq" or enable_caching or rate_limiting == "redis" %]
    "redis>=6.2.0",
[% endif %]
[% if background_tasks == "taskiq" %]
    "taskiq>=0.11.18",
    "taskiq-redis>=1.0.9",
[% endif %]
[% if enable_caching %]
    "fastapi-cache2>=0.2.2",
[% endif %]
[% if database == "postgresql" %]
    "alembic>=1.16.0",
    "asyncpg>=0.30.0",
[% if orm == "sqlalchemy" %]
    "sqlalchemy[asyncio]>=2.0.41",
[% else %]
    "sqlmodel>=0.0.24",
[% endif %]
[% endif %]
[% if agent_capability == "pydantic-ai" %]
    "pydantic-ai-slim[openai]>=2.0.0",
[% endif %]
    "uvicorn[standard]>=0.34.0",
]


[dependency-groups]
dev = [
    "anyio>=4.9.0",
    "httpx>=0.28.1",
    "pytest>=8.4.1",
    "pytest-cov>=6.2.1",
    "ruff>=0.12.4",
    "ty>=0.0.1a16",
]

[tool.ruff]
line-length = 100
target-version = "py[[ python_version | replace('.', '') ]]"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM", "RUF"]

[tool.pytest.ini_options]
addopts = "-q --cov=app --cov-report=term-missing"
testpaths = ["tests"]

[tool.ty.src]
include = ["app", "tests"]

[tool.coverage.run]
source = ["app"]
[% if database == "postgresql" %]
concurrency = ["greenlet", "thread"]
[% endif %]

[tool.coverage.report]
fail_under = 100
show_missing = true
