[project]
name = "[[ project_slug ]]"
version = "0.1.0"
description = "[[ project_description ]]"
readme = "README.md"
requires-python = ">=[[ python_version ]]"
authors = [
    { name = "[[ author_name ]]", email = "[[ author_email ]]" },
]
dependencies = [
    "click>=8.2.1",
    "fastapi[standard]>=0.135.3,<0.137",
    "pydantic-settings>=2.7.0",
    "tabulate>=0.9.0",
    "uvicorn[standard]>=0.34.0",
[% if database == "postgresql" %]
    "alembic>=1.16.0",
    "asyncpg>=0.30.0",
[% if orm_type == "sqlalchemy" %]
    "sqlalchemy[asyncio]>=2.0.41",
[% else %]
    "sqlmodel>=0.0.24",
[% endif %]
[% endif %]
[% if enable_redis %]
    "redis>=6.2.0",
[% endif %]
[% if background_tasks == "taskiq" %]
    "taskiq>=0.11.18",
    "taskiq-redis>=1.0.9",
[% endif %]
[% if enable_caching %]
    "fastapi-cache2>=0.2.2",
[% endif %]
[% if enable_rate_limiting %]
    "slowapi>=0.1.9",
[% endif %]
[% if ai_framework == "pydantic_ai" %]
    "pydantic-ai-slim[openai]>=2.0.0",
[% endif %]
[% if enable_logfire and ai_framework == "pydantic_ai" %]
    "logfire[pydantic-ai]>=4.0.0",
[% endif %]
]

[project.scripts]
[[ project_slug ]] = "cli.commands:cli"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["app", "cli"]

[dependency-groups]
dev = [
    "anyio>=4.9.0",
    "httpx>=0.28.1",
    "pytest>=8.4.1",
    "pytest-cov>=6.2.1",
    "ruff>=0.12.4",
    "ty>=0.0.1a16",
]

[tool.ruff]
line-length = 100
target-version = "py[[ python_version | replace('.', '') ]]"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM", "RUF"]

[tool.pytest.ini_options]
testpaths = ["tests"]

[tool.ty.src]
include = ["app", "cli", "tests"]

[tool.coverage.run]
source = ["app", "cli"]
[% if database == "postgresql" %]
concurrency = ["greenlet", "thread"]
[% endif %]

[tool.coverage.report]
fail_under = 100
show_missing = true
