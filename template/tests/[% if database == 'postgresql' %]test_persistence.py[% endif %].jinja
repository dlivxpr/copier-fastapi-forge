from __future__ import annotations

from uuid import UUID, uuid4

import pytest
from httpx import AsyncClient
from sqlalchemy.exc import IntegrityError, SQLAlchemyError
[% if orm == "sqlalchemy" %]from sqlalchemy.ext.asyncio import AsyncSession
[% else %]from sqlmodel.ext.asyncio.session import AsyncSession
[% endif %]
from app.api.deps import get_resource_service
from app.core.config import Settings
from app.core.exceptions import ConflictError, PersistenceError
from app.core.pagination import PaginationParams
from app.db.session import DatabaseSessionManager, database
from app.main import app
from app.models.resource import Resource
from app.repositories.resource import ResourceRepository
from app.schemas.resource import ResourceCreate, ResourceUpdate
from app.services.resource import ResourceService

pytestmark = pytest.mark.anyio


class FailingRepository(ResourceRepository):
    def __init__(self) -> None:
        pass

    async def create(self, *, name: str, description: str | None) -> Resource:
        raise SQLAlchemyError("create failed")

    async def get(self, resource_id: UUID) -> Resource | None:
        raise SQLAlchemyError("get failed")

    async def list_resources(self, pagination: PaginationParams) -> tuple[list[Resource], int]:
        raise SQLAlchemyError("list failed")


class MutationFailingRepository(ResourceRepository):
    def __init__(self) -> None:
        self.resource = Resource(name=f"resource-{uuid4()}", description=None)

    async def get(self, resource_id: UUID) -> Resource | None:
        return self.resource

    async def update(self, resource: Resource, updates: dict[str, object]) -> Resource:
        raise SQLAlchemyError("update failed")

    async def delete(self, resource: Resource) -> None:
        raise SQLAlchemyError("delete failed")


class ConflictRepository(ResourceRepository):
    def __init__(self) -> None:
        pass

    async def create(self, *, name: str, description: str | None) -> Resource:
        raise IntegrityError("insert", {}, Exception("duplicate"))


async def test_service_translates_repository_failures() -> None:
    failing_service = ResourceService(FailingRepository())
    with pytest.raises(PersistenceError):
        await failing_service.create(ResourceCreate(name="failing-create"))
    with pytest.raises(PersistenceError):
        await failing_service.list_resources(PaginationParams())

    mutation_service = ResourceService(MutationFailingRepository())
    resource_id = uuid4()
    with pytest.raises(PersistenceError):
        await mutation_service.update(resource_id, ResourceUpdate(description="updated"))
    with pytest.raises(PersistenceError):
        await mutation_service.delete(resource_id)

    with pytest.raises(ConflictError):
        await ResourceService(ConflictRepository()).create(ResourceCreate(name="duplicate"))


async def test_persistence_failure_uses_error_envelope(
    client: AsyncClient,
    api_key_headers: dict[str, str],
) -> None:
    app.dependency_overrides[get_resource_service] = lambda: ResourceService(FailingRepository())

    response = await client.get(f"/api/v1/resources/{uuid4()}", headers=api_key_headers)

    assert response.status_code == 500
    assert response.json()["error"]["code"] == "PERSISTENCE_ERROR"


async def test_session_manager_rejects_invalid_lifecycle() -> None:
    manager = DatabaseSessionManager()
    with pytest.raises(RuntimeError, match="not initialized"):
        async with manager.session():
            pass
    with pytest.raises(RuntimeError, match="not initialized"):
        await manager.check_connection()
    await manager.close()

    manager.initialize(Settings().database_url)
    with pytest.raises(RuntimeError, match="already initialized"):
        manager.initialize(Settings().database_url)
    await manager.close()


async def test_commit_failure_rolls_back(
    monkeypatch: pytest.MonkeyPatch,
) -> None:
    original_commit = AsyncSession.commit
    failed = False

    async def fail_once(session: AsyncSession) -> None:
        nonlocal failed
        if not failed:
            failed = True
            raise SQLAlchemyError("commit failed")
        await original_commit(session)

    monkeypatch.setattr(AsyncSession, "commit", fail_once)
    resource = Resource(name=f"resource-{uuid4()}", description=None)

    with pytest.raises(PersistenceError):
        async with database.session() as session:
            session.add(resource)
            await session.flush()

    async with database.session() as session:
        assert await session.get(Resource, resource.id) is None
