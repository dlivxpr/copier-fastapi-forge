from __future__ import annotations

from httpx import AsyncClient


async def test_liveness_unauthenticated(client: AsyncClient) -> None:
    response = await client.get("/health/live")
    assert response.status_code == 200
    assert response.json() == {"status": "alive"}


async def test_readiness_unauthenticated(client: AsyncClient) -> None:
    response = await client.get("/health/ready")
    assert response.status_code == 200
    assert response.json() == {"status": "ready"}


async def test_business_route_rejected_without_api_key(client: AsyncClient) -> None:
    response = await client.get("/api/v1/hello")
    assert response.status_code == 401
    body = response.json()
    assert body["error"]["code"] == "UNAUTHORIZED"


async def test_business_route_rejected_with_wrong_api_key(client: AsyncClient) -> None:
    response = await client.get("/api/v1/hello", headers={"X-API-Key": "wrong-key"})
    assert response.status_code == 401
    body = response.json()
    assert body["error"]["code"] == "UNAUTHORIZED"


async def test_business_route_accepted_with_valid_key(
    client: AsyncClient, api_key_headers: dict[str, str]
) -> None:
    response = await client.get("/api/v1/hello", headers=api_key_headers)
    assert response.status_code == 200
    assert response.json()["message"] == "Hello, world!"


async def test_hello_accepts_name_param(
    client: AsyncClient, api_key_headers: dict[str, str]
) -> None:
    response = await client.get("/api/v1/hello?name=Alice", headers=api_key_headers)
    assert response.status_code == 200
    assert response.json()["message"] == "Hello, Alice!"


async def test_error_envelope_on_not_found(
    client: AsyncClient, api_key_headers: dict[str, str]
) -> None:
    response = await client.get("/api/v1/items/nonexistent", headers=api_key_headers)
    assert response.status_code == 404
    body = response.json()
    assert body["error"]["code"] == "NOT_FOUND"
    assert "Item" in body["error"]["message"]
    assert body["error"]["details"]["resource"] == "Item"
    assert body["error"]["details"]["identifier"] == "nonexistent"


async def test_cors_headers_present_on_preflight(client: AsyncClient) -> None:
    response = await client.options(
        "/health/live",
        headers={
            "Origin": "https://example.com",
            "Access-Control-Request-Method": "GET",
        },
    )
    assert response.status_code == 200
    assert "access-control-allow-origin" in response.headers
