async def test_resource_routes_require_api_key(client: AsyncClient) -> None:
    response = await client.get("/api/v1/resources")
    assert response.status_code == 401
    assert response.json()["error"]["code"] == "UNAUTHORIZED"


async def test_resource_crud_and_pagination_contract(
    client: AsyncClient, api_key_headers: dict[str, str]
) -> None:
    names = [f"resource-{uuid4()}" for _ in range(3)]
    created = []
    for index, name in enumerate(names):
        response = await client.post(
            "/api/v1/resources",
            headers=api_key_headers,
            json={"name": name, "description": f"description-{index}"},
        )
        assert response.status_code == 201
        created.append(response.json())

    page = await client.get(
        "/api/v1/resources?offset=1&limit=2",
        headers=api_key_headers,
    )
    assert page.status_code == 200
    assert page.json()["total"] == 3
    assert page.json()["offset"] == 1
    assert page.json()["limit"] == 2
    assert len(page.json()["items"]) == 2

    resource_id = created[0]["id"]
    fetched = await client.get(f"/api/v1/resources/{resource_id}", headers=api_key_headers)
    assert fetched.status_code == 200
    assert fetched.json()["name"] == names[0]

    updated = await client.patch(
        f"/api/v1/resources/{resource_id}",
        headers=api_key_headers,
        json={"description": "updated"},
    )
    assert updated.status_code == 200
    assert updated.json()["description"] == "updated"

    deleted = await client.delete(
        f"/api/v1/resources/{resource_id}",
        headers=api_key_headers,
    )
    assert deleted.status_code == 204

    missing = await client.get(f"/api/v1/resources/{resource_id}", headers=api_key_headers)
    assert missing.status_code == 404
    assert missing.json()["error"]["code"] == "NOT_FOUND"


async def test_duplicate_update_rolls_back_persistent_state(
    client: AsyncClient, api_key_headers: dict[str, str]
) -> None:
    first_name = f"resource-{uuid4()}"
    second_name = f"resource-{uuid4()}"
    first = await client.post(
        "/api/v1/resources",
        headers=api_key_headers,
        json={"name": first_name},
    )
    second = await client.post(
        "/api/v1/resources",
        headers=api_key_headers,
        json={"name": second_name},
    )
    assert first.status_code == 201
    assert second.status_code == 201

    second_id = second.json()["id"]
    duplicate = await client.patch(
        f"/api/v1/resources/{second_id}",
        headers=api_key_headers,
        json={"name": first_name},
    )
    assert duplicate.status_code == 409
    assert duplicate.json()["error"]["code"] == "CONFLICT"

    persisted = await client.get(
        f"/api/v1/resources/{second_id}",
        headers=api_key_headers,
    )
    assert persisted.status_code == 200
    assert persisted.json()["name"] == second_name

    after_failure = await client.post(
        "/api/v1/resources",
        headers=api_key_headers,
        json={"name": f"resource-{uuid4()}"},
    )
    assert after_failure.status_code == 201
