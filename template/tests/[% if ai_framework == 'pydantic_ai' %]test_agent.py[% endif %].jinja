from __future__ import annotations

import json
import threading
from collections.abc import Iterator
from contextlib import contextmanager
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any

import pytest
from httpx import AsyncClient

from app.api.deps import get_agent
from app.core.config import settings

pytestmark = pytest.mark.anyio


class FakeChatState:
    def __init__(self) -> None:
        self.requests: list[dict[str, Any]] = []
        self.authorization_headers: list[str | None] = []


def user_content(messages: list[dict[str, Any]]) -> str:
    for message in reversed(messages):
        if message.get("role") == "user":
            content = message.get("content", "")
            if isinstance(content, str):
                return content
    return ""


def completion_chunk(delta: dict[str, Any], finish_reason: str | None = None) -> str:
    return json.dumps(
        {
            "id": "chatcmpl-fake",
            "object": "chat.completion.chunk",
            "created": 1,
            "model": "fake-model",
            "choices": [
                {
                    "index": 0,
                    "delta": delta,
                    "finish_reason": finish_reason,
                }
            ],
        }
    )


def make_chat_handler(state: FakeChatState) -> type[BaseHTTPRequestHandler]:
    class ChatHandler(BaseHTTPRequestHandler):
        def do_POST(self) -> None:
            if self.path != "/v1/chat/completions":
                self.send_error(404)
                return

            length = int(self.headers.get("Content-Length", "0"))
            payload = json.loads(self.rfile.read(length))
            state.requests.append(payload)
            state.authorization_headers.append(self.headers.get("Authorization"))
            messages = payload["messages"]
            current_input = user_content(messages)

            if current_input == "fail":
                body = json.dumps(
                    {
                        "error": {
                            "message": "model unavailable",
                            "type": "server_error",
                            "code": "server_error",
                        }
                    }
                ).encode()
                self.send_response(500)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return

            has_tool_result = any(message.get("role") == "tool" for message in messages)
            wants_tool = current_input == "use current time"
            if payload.get("stream"):
                self.send_response(200)
                self.send_header("Content-Type", "text/event-stream")
                self.end_headers()
                if wants_tool and not has_tool_result:
                    chunks = [
                        completion_chunk(
                            {
                                "role": "assistant",
                                "tool_calls": [
                                    {
                                        "index": 0,
                                        "id": "call-time",
                                        "type": "function",
                                        "function": {
                                            "name": "current_datetime",
                                            "arguments": "{}",
                                        },
                                    }
                                ],
                            }
                        ),
                        completion_chunk({}, "tool_calls"),
                    ]
                else:
                    output = "time returned" if has_tool_result else f"reply:{current_input}"
                    midpoint = max(1, len(output) // 2)
                    chunks = [
                        completion_chunk({"role": "assistant", "content": output[:midpoint]}),
                        completion_chunk({"content": output[midpoint:]}),
                        completion_chunk({}, "stop"),
                    ]
                for chunk in chunks:
                    self.wfile.write(f"data: {chunk}\n\n".encode())
                    self.wfile.flush()
                self.wfile.write(b"data: [DONE]\n\n")
                self.wfile.flush()
                return

            output = f"reply:{current_input}"
            body = json.dumps(
                {
                    "id": "chatcmpl-fake",
                    "object": "chat.completion",
                    "created": 1,
                    "model": "fake-model",
                    "choices": [
                        {
                            "index": 0,
                            "message": {"role": "assistant", "content": output},
                            "finish_reason": "stop",
                        }
                    ],
                    "usage": {
                        "prompt_tokens": 1,
                        "completion_tokens": 1,
                        "total_tokens": 2,
                    },
                }
            ).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def log_message(self, format: str, *args: object) -> None:
            del format, args

    return ChatHandler


@contextmanager
def serve_fake_chat(state: FakeChatState) -> Iterator[str]:
    server = ThreadingHTTPServer(("127.0.0.1", 0), make_chat_handler(state))
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()
    try:
        yield f"http://127.0.0.1:{server.server_port}"
    finally:
        server.shutdown()
        thread.join(timeout=5)
        server.server_close()


@pytest.fixture(scope="module")
def fake_chat() -> Iterator[tuple[str, FakeChatState]]:
    state = FakeChatState()
    with serve_fake_chat(state) as base_url:
        yield base_url, state


@pytest.fixture(autouse=True)
def configure_fake_model(fake_chat: tuple[str, FakeChatState]) -> Iterator[None]:
    base_url, _ = fake_chat
    previous = (settings.LLM_BASE_URL, settings.LLM_API_KEY, settings.LLM_MODEL)
    settings.LLM_BASE_URL = f"{base_url}/v1"
    settings.LLM_API_KEY = "test-model-key"
    settings.LLM_MODEL = "fake-model"
    get_agent.cache_clear()
    yield
    get_agent.cache_clear()
    settings.LLM_BASE_URL, settings.LLM_API_KEY, settings.LLM_MODEL = previous


def parse_sse(body: str) -> list[tuple[str, dict[str, Any]]]:
    frames = []
    for block in body.replace("\r\n", "\n").strip().split("\n\n"):
        fields = dict(line.split(": ", 1) for line in block.splitlines())
        frames.append((fields["event"], json.loads(fields["data"])))
    return frames


async def test_json_operation_uses_real_chat_completions_http(
    client: AsyncClient,
    api_key_headers: dict[str, str],
    fake_chat: tuple[str, FakeChatState],
) -> None:
    _, state = fake_chat
    state.requests.clear()
    state.authorization_headers.clear()

    response = await client.post(
        "/agent/run",
        headers=api_key_headers,
        json={"input": "first request"},
    )

    assert response.status_code == 200
    assert response.json() == {"output": "reply:first request"}
    assert state.requests[-1]["model"] == "fake-model"
    assert state.authorization_headers[-1] == "Bearer test-model-key"


@pytest.mark.parametrize("route", ["/agent/run", "/agent/stream"])
async def test_agent_routes_enforce_api_key_and_body_schema(
    client: AsyncClient,
    api_key_headers: dict[str, str],
    route: str,
) -> None:
    missing = await client.post(route, json={"input": "hello"})
    invalid = await client.post(
        route,
        headers={"X-API-Key": "wrong"},
        json={"input": "hello"},
    )
    empty = await client.post(route, headers=api_key_headers, json={"input": ""})
    history = await client.post(
        route,
        headers=api_key_headers,
        json={"input": "hello", "history": []},
    )

    assert missing.status_code == 401
    assert invalid.status_code == 403
    assert empty.status_code == 422
    assert history.status_code == 422


async def test_requests_do_not_share_message_history(
    client: AsyncClient,
    api_key_headers: dict[str, str],
    fake_chat: tuple[str, FakeChatState],
) -> None:
    _, state = fake_chat
    state.requests.clear()

    first = await client.post(
        "/agent/run",
        headers=api_key_headers,
        json={"input": "alpha"},
    )
    second = await client.post(
        "/agent/run",
        headers=api_key_headers,
        json={"input": "beta"},
    )

    assert first.json() == {"output": "reply:alpha"}
    assert second.json() == {"output": "reply:beta"}
    request_messages = [request["messages"] for request in state.requests]
    assert [user_content(messages) for messages in request_messages] == ["alpha", "beta"]
    for messages in request_messages:
        assert [message["role"] for message in messages].count("user") == 1
        assert all(message["role"] not in {"assistant", "tool"} for message in messages)


async def test_sse_frames_content_tool_and_completion_events(
    client: AsyncClient,
    api_key_headers: dict[str, str],
) -> None:
    response = await client.post(
        "/agent/stream",
        headers=api_key_headers,
        json={"input": "use current time"},
    )

    assert response.status_code == 200
    frames = parse_sse(response.text)
    events = [event for event, _ in frames]
    assert events.count("tool_call") == 1
    assert events.count("tool_result") == 1
    assert "content" in events
    assert events[-1] == "complete"
    assert frames[-1] == ("complete", {"output": "time returned"})


async def test_json_and_sse_failures_have_stable_framing(
    client: AsyncClient,
    api_key_headers: dict[str, str],
) -> None:
    json_response = await client.post(
        "/agent/run",
        headers=api_key_headers,
        json={"input": "fail"},
    )
    sse_response = await client.post(
        "/agent/stream",
        headers=api_key_headers,
        json={"input": "fail"},
    )

    assert json_response.status_code == 502
    assert json_response.json() == {
        "error": {
            "code": "AGENT_INVOCATION_ERROR",
            "message": "Agent invocation failed",
            "details": None,
        }
    }
    assert parse_sse(sse_response.text) == [
        (
            "error",
            {
                "code": "AGENT_INVOCATION_ERROR",
                "message": "Agent invocation failed",
            },
        )
    ]


async def test_closing_stream_releases_agent_event_context(
    client: AsyncClient,
    api_key_headers: dict[str, str],
) -> None:
    response = await client.post(
        "/agent/stream",
        headers=api_key_headers,
        json={"input": "disconnect"},
    )
    assert response.status_code == 200
    assert parse_sse(response.text)[-1] == (
        "complete",
        {"output": "reply:disconnect"},
    )


[% if enable_logfire -%]
def test_logfire_is_configured_before_content_safe_agent_instrumentation(
    monkeypatch: pytest.MonkeyPatch,
) -> None:
    from app.core import telemetry

    calls: list[tuple[str, dict[str, Any]]] = []
    monkeypatch.setattr(
        telemetry.logfire,
        "configure",
        lambda **kwargs: calls.append(("configure", kwargs)),
    )
    monkeypatch.setattr(
        telemetry.logfire,
        "instrument_pydantic_ai",
        lambda **kwargs: calls.append(("instrument_pydantic_ai", kwargs)),
    )
    for name in (
        "instrument_fastapi",
        "instrument_sqlalchemy",
        "instrument_redis",
        "instrument_httpx",
    ):
        monkeypatch.setattr(
            telemetry.logfire,
            name,
            lambda *args, _name=name, **kwargs: calls.append((_name, kwargs)),
        )

    telemetry.configure_telemetry.cache_clear()
    telemetry.configure_telemetry()

    assert [name for name, _ in calls] == ["configure", "instrument_pydantic_ai"]
    assert calls[1][1] == {
        "include_content": False,
        "include_binary_content": False,
    }
