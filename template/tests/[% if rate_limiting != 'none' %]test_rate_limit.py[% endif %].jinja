from __future__ import annotations

import asyncio

import pytest
from httpx import AsyncClient

pytestmark = pytest.mark.anyio


async def test_quota_error_envelope_and_window_recovery(
    client: AsyncClient, api_key_headers: dict[str, str]
) -> None:
    accepted = []
    for _ in range([[ rate_limit_requests ]]):
        accepted.append(await client.get("/api/v1/limited", headers=api_key_headers))
    assert all(response.status_code == 200 for response in accepted)

    rejected = await client.get("/api/v1/limited", headers=api_key_headers)
    assert rejected.status_code == 429
    assert rejected.json() == {
        "error": {
            "code": "RATE_LIMIT_EXCEEDED",
            "message": "Rate limit exceeded",
            "details": {"retry_after_seconds": [[ rate_limit_period_seconds ]]},
        }
    }

    await asyncio.sleep([[ rate_limit_period_seconds ]] + 0.05)
    recovered = await client.get("/api/v1/limited", headers=api_key_headers)
    assert recovered.status_code == 200
