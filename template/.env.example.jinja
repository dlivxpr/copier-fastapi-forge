# [[ project_name ]] environment variables
# Copy to .env and fill in values

# Deployment API key — shared by all callers to this deployment
API_KEY=[[ deployment_api_key ]]

# CORS allowed origins (comma-separated)
CORS_ORIGINS=*
[% if database == "postgresql" %]
# PostgreSQL async connection URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/app

[% endif %]

[% if background_tasks == "taskiq" or enable_caching or rate_limiting == "redis" %]
# Shared Redis connection used by every enabled Redis consumer
REDIS_URL=redis://127.0.0.1:6379/0

[% endif %]
[% if rate_limiting != "none" %]
# HTTP rate limit quota and fixed-window duration
RATE_LIMIT_REQUESTS=[[ rate_limit_requests ]]
RATE_LIMIT_PERIOD_SECONDS=[[ rate_limit_period_seconds ]]

[% endif %]
# Server
HOST=0.0.0.0
PORT=8000
