# [[ project_name ]] environment variables
# Copy to .env and fill in values

PROJECT_NAME=[[ project_name ]]
ENVIRONMENT=local
TIMEZONE=[[ timezone ]]
API_KEY=[[ deployment_api_key ]]
API_KEY_HEADER=X-API-Key
[% if database == "postgresql" %]
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=[[ project_slug ]]
DB_POOL_SIZE=[[ db_pool_size ]]
DB_MAX_OVERFLOW=[[ db_max_overflow ]]
DB_POOL_TIMEOUT=[[ db_pool_timeout ]]
[% endif %]
[% if enable_redis %]
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
[% endif %]
[% if enable_rate_limiting %]
RATE_LIMIT_REQUESTS=[[ rate_limit_requests ]]
RATE_LIMIT_PERIOD=[[ rate_limit_period ]]
RATE_LIMIT_STORAGE=[[ rate_limit_storage ]]
[% endif %]
[% if ai_framework == "pydantic_ai" %]
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=model-key-CHANGEME
LLM_MODEL=model-name-CHANGEME
[% endif %]
[% if enable_logfire %]
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=[[ project_slug ]]
LOGFIRE_ENVIRONMENT=development
[% endif %]
[% if enable_cors %]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
[% endif %]
