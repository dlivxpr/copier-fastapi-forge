from __future__ import annotations

from datetime import UTC, datetime
from uuid import UUID

[% if orm == "sqlalchemy" %]from sqlalchemy import func, select
from sqlalchemy.ext.asyncio import AsyncSession
[% else %]from sqlalchemy import func
from sqlmodel import col, select
from sqlmodel.ext.asyncio.session import AsyncSession
[% endif %]
from app.core.pagination import PaginationParams
from app.models.resource import Resource


class ResourceRepository:
    def __init__(self, session: AsyncSession) -> None:
        self.session = session

    async def create(self, *, name: str, description: str | None) -> Resource:
        resource = Resource(name=name, description=description)
        self.session.add(resource)
        await self.session.flush()
        await self.session.refresh(resource)
        return resource

    async def get(self, resource_id: UUID) -> Resource | None:
        return await self.session.get(Resource, resource_id)

    async def list_resources(self, pagination: PaginationParams) -> tuple[list[Resource], int]:
[% if orm == "sqlalchemy" %]        statement = (
            select(Resource)
            .order_by(Resource.created_at, Resource.id)
            .offset(pagination.offset)
            .limit(pagination.limit)
        )
[% else %]        statement = (
            select(Resource)
            .order_by(col(Resource.created_at), col(Resource.id))
            .offset(pagination.offset)
            .limit(pagination.limit)
        )
[% endif %][% if orm == "sqlalchemy" %]        resources = list((await self.session.scalars(statement)).all())
        total = await self.session.scalar(select(func.count()).select_from(Resource))
[% else %]        resources = list((await self.session.exec(statement)).all())
        total = (await self.session.exec(select(func.count()).select_from(Resource))).one()
[% endif %]        return resources, int(total or 0)

    async def update(self, resource: Resource, updates: dict[str, object]) -> Resource:
        for field, value in updates.items():
            setattr(resource, field, value)
        resource.updated_at = datetime.now(UTC)
        await self.session.flush()
        await self.session.refresh(resource)
        return resource

    async def delete(self, resource: Resource) -> None:
        await self.session.delete(resource)
        await self.session.flush()
