from __future__ import annotations

from collections.abc import AsyncGenerator
from typing import cast

from redis.asyncio import Redis
from taskiq import AckableMessage
from taskiq_redis import RedisStreamBroker

type StreamMessage = tuple[bytes, dict[bytes, bytes]]
type StreamReadResult = list[tuple[bytes, list[StreamMessage]]]
type AutoClaimResult = tuple[bytes, list[StreamMessage], list[bytes]]


class PendingAwareRedisStreamBroker(RedisStreamBroker):
    """Redis Stream broker that reclaims idle pending tasks without new traffic."""

    async def listen(self) -> AsyncGenerator[AckableMessage]:
        """Read new tasks and scan idle pending tasks after every blocking read."""
        async with Redis(connection_pool=self.connection_pool) as redis_conn:
            while True:
                fetched = await redis_conn.xreadgroup(
                    self.consumer_group_name,
                    self.consumer_name,
                    {
                        self.queue_name: ">",
                        **self.additional_streams,  # type: ignore[dict-item]
                    },
                    block=self.block,
                    noack=False,
                    count=self.count,
                )
                for stream, messages in cast(StreamReadResult, fetched):
                    queue_name = stream.decode()
                    for message_id, message in messages:
                        yield AckableMessage(
                            data=message[b"data"],
                            ack=self._ack_generator(
                                id=message_id.decode(),
                                queue_name=queue_name,
                            ),
                        )

                for stream in [self.queue_name, *self.additional_streams]:
                    pipe = redis_conn.pipeline()
                    lock = pipe.lock(
                        f"autoclaim:{self.consumer_group_name}:{stream}",
                        timeout=self.unacknowledged_lock_timeout,
                    )
                    await lock.acquire()
                    await pipe.xautoclaim(
                        name=stream,
                        groupname=self.consumer_group_name,
                        consumername=self.consumer_name,
                        min_idle_time=self.idle_timeout,
                        count=self.unacknowledged_batch_size,
                    )
                    await lock.release()
                    results = await pipe.execute()
                    pending = cast(AutoClaimResult, results[1])

                    for message_id, message in pending[1]:
                        yield AckableMessage(
                            data=message[b"data"],
                            ack=self._ack_generator(
                                id=message_id.decode(),
                                queue_name=stream,
                            ),
                        )
