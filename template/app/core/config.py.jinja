from __future__ import annotations

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=False,
    )

    api_key: str = "[[ deployment_api_key ]]"
    cors_origins: str = "*"
    host: str = "0.0.0.0"
    port: int = 8000
[% if background_tasks == "taskiq" or enable_caching or rate_limiting == "redis" %]    redis_url: str = "redis://127.0.0.1:6379/0"
[% endif %][% if rate_limiting != "none" %]    rate_limit_requests: int = [[ rate_limit_requests ]]
    rate_limit_period_seconds: int = [[ rate_limit_period_seconds ]]
[% endif %][% if database == "postgresql" %]    database_url: str = "postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/app"
[% endif -%]
