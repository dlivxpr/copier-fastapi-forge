"""HTTP rate limiting configuration."""

from typing import Any

from slowapi import Limiter
from slowapi.util import get_remote_address

from app.core.config import settings


def get_default_rate_limit() -> str:
    """Return the configured default limit in SlowAPI notation."""
    periods = {60: "minute", 3600: "hour", 86400: "day"}
    unit = periods.get(settings.RATE_LIMIT_PERIOD)
    if unit is not None:
        return f"{settings.RATE_LIMIT_REQUESTS}/{unit}"
    return f"{settings.RATE_LIMIT_REQUESTS}/{settings.RATE_LIMIT_PERIOD} seconds"


limiter = Limiter(
    key_func=get_remote_address,
    default_limits=[get_default_rate_limit()],
[% if rate_limit_storage == "redis" %]    storage_uri=settings.REDIS_URL,
[% else %]    storage_uri="memory://",
[% endif %])


def rate_limit_low(limit: str = "10/minute") -> Any:
    """Apply the low-throughput policy for expensive operations."""
    return limiter.limit(limit)


def rate_limit_medium(limit: str = "30/minute") -> Any:
    """Apply the medium-throughput policy for standard operations."""
    return limiter.limit(limit)


def rate_limit_high(limit: str = "100/minute") -> Any:
    """Apply the high-throughput policy for lightweight operations."""
    return limiter.limit(limit)
