from __future__ import annotations

from collections.abc import AsyncIterator
from contextlib import asynccontextmanager

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
[% if enable_caching %]from fastapi_cache import FastAPICache
from fastapi_cache.backends.redis import RedisBackend
[% endif %]
from app.api.exception_handlers import register_exception_handlers
from app.api.router import router
from app.core.config import Settings
[% if rate_limiting != "none" %]from app.core.rate_limit import RateLimiter
[% endif %][% if background_tasks == "taskiq" or enable_caching or rate_limiting == "redis" %]from app.core.redis import redis_resources
[% endif %][% if database == "postgresql" %]from app.db.session import database
[% endif %]
settings = Settings()


@asynccontextmanager
async def lifespan(app: FastAPI) -> AsyncIterator[None]:
    """Initialize and tear down shared resources."""
[% if database == "postgresql" %]    database.initialize(settings.database_url)
[% endif %][% if background_tasks == "taskiq" or enable_caching or rate_limiting == "redis" %]    redis_resources.initialize(settings.redis_url)
[% endif %][% if enable_caching %]    FastAPICache.init(RedisBackend(redis_resources.client), prefix="service-cache")
[% endif %][% if rate_limiting != "none" %]    app.state.rate_limiter = RateLimiter(
        limit=settings.rate_limit_requests,
        period_seconds=settings.rate_limit_period_seconds,
[% if rate_limiting == "redis" %]        redis_client=redis_resources.client,
[% endif %]    )
[% endif %]    try:
        yield
    finally:
[% if background_tasks == "taskiq" or enable_caching or rate_limiting == "redis" %]        await redis_resources.close()
[% endif %][% if database == "postgresql" %]        await database.close()
[% endif %][% if database != "postgresql" and background_tasks != "taskiq" and not enable_caching and rate_limiting != "redis" %]        pass
[% endif %]

app = FastAPI(
    title="[[ project_name ]]",
    description="[[ project_description ]]",
    lifespan=lifespan,
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=[o.strip() for o in settings.cors_origins.split(",")],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

register_exception_handlers(app)
app.include_router(router, prefix="/api/v1")


@app.get("/health/live")
async def liveness() -> dict[str, str]:
    return {"status": "alive"}


@app.get("/health/ready")
async def readiness() -> dict[str, str]:
[% if database == "postgresql" %]
    await database.check_connection()
[% endif %]
    return {"status": "ready"}
