"""FastAPI application entry point."""

from collections.abc import AsyncIterator
from contextlib import asynccontextmanager

from fastapi import FastAPI[% if enable_rate_limiting %], Request[% endif %]
[% if enable_rate_limiting %]from slowapi.errors import RateLimitExceeded
from slowapi.middleware import SlowAPIASGIMiddleware
[% endif %][% if enable_cors %]from starlette.middleware.cors import CORSMiddleware
[% endif %][% if enable_rate_limiting %]from starlette.responses import Response
[% endif %]
[% if ai_framework == "pydantic_ai" %]from app.api.agent import router as agent_router
[% endif -%]
from app.api.exception_handlers import [% if enable_rate_limiting %]app_exception_handler, [% endif %]register_exception_handlers
from app.api.health import router as health_router
from app.api.router import api_router
[% if enable_redis %]from app.clients.redis import RedisClient
[% endif %][% if enable_caching %]from app.core.cache import close_cache, setup_cache
[% endif %]from app.core.config import settings
[% if enable_rate_limiting %]from app.core.exceptions import RateLimitError
[% endif %]from app.core.logging import setup_logging
from app.core.middleware import RequestIDMiddleware
[% if enable_rate_limiting %]from app.core.rate_limit import limiter
[% endif %][% if ai_framework == "pydantic_ai" and enable_logfire %]from app.core.telemetry import configure_telemetry
[% endif %][% if database == "postgresql" %]from app.db.session import close_db
[% endif -%]
[[ "\n\n" -]]
[% if enable_rate_limiting %]async def slowapi_exception_handler(
    request: Request,
    exc: Exception,
) -> Response:
    """Translate SlowAPI errors into the public error envelope."""
    if not isinstance(exc, RateLimitExceeded):
        raise exc
    return await app_exception_handler(request, RateLimitError())


[% endif -%]
@asynccontextmanager
async def lifespan(app: FastAPI) -> AsyncIterator[None]:
    """Initialize and close resources owned by the API process."""
[% if enable_redis %]    redis = RedisClient()
    await redis.connect()
    app.state.redis = redis
[% endif %][% if enable_caching %]    setup_cache(redis)
[% endif %][% if database == "postgresql" or enable_redis %]    try:
        yield
    finally:
[% if enable_caching %]        close_cache()
[% endif %][% if enable_redis %]        await redis.close()
        del app.state.redis
[% endif %][% if database == "postgresql" %]        await close_db()
[% endif %][% else %]    yield
[% endif %]

SHOW_DOCS_ENVIRONMENTS = ("local", "staging", "development")


def create_app() -> FastAPI:
    """Create and configure the FastAPI application."""
    show_docs = settings.ENVIRONMENT in SHOW_DOCS_ENVIRONMENTS
    setup_logging()
[% if ai_framework == "pydantic_ai" and enable_logfire %]    configure_telemetry()
[% endif %]
    app = FastAPI(
        title=settings.PROJECT_NAME,
        summary="FastAPI application",
        description="[[ project_description ]]",
        version="0.1.0",
        openapi_url=f"{settings.API_V1_STR}/openapi.json" if show_docs else None,
        docs_url="/docs" if show_docs else None,
        redoc_url="/redoc" if show_docs else None,
        contact={"name": "[[ author_name ]]", "email": "[[ author_email ]]"},
        license_info={"name": "MIT", "identifier": "MIT"},
        lifespan=lifespan,
    )
    app.add_middleware(RequestIDMiddleware)
    register_exception_handlers(app)
[% if enable_rate_limiting %]    app.state.limiter = limiter
    app.add_exception_handler(RateLimitExceeded, slowapi_exception_handler)
    app.add_middleware(SlowAPIASGIMiddleware)
[% endif %]
[% if enable_cors %]    app.add_middleware(
        CORSMiddleware,
        allow_origins=settings.CORS_ORIGINS,
        allow_credentials=settings.CORS_ALLOW_CREDENTIALS,
        allow_methods=settings.CORS_ALLOW_METHODS,
        allow_headers=settings.CORS_ALLOW_HEADERS,
    )
[% endif %]    app.include_router(health_router)
[% if ai_framework == "pydantic_ai" %]    app.include_router(agent_router)
[% endif %]
    app.include_router(api_router, prefix=settings.API_V1_STR)
    return app


app = create_app()
