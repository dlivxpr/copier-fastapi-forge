from __future__ import annotations

from time import time_ns

from fastapi import APIRouter, Response, status
from fastapi_cache import FastAPICache
from fastapi_cache.decorator import cache

router = APIRouter(prefix="/cache", tags=["cache"])


@router.get("/{key}")
@cache(expire=60, namespace="demo")
async def get_cached_value(key: str, response: Response) -> dict[str, str | int]:
    """Return a value whose timestamp changes only on a cache miss."""
    return {"key": key, "generated_at": time_ns()}


@router.delete("", status_code=status.HTTP_204_NO_CONTENT)
async def invalidate_cache() -> None:
    """Invalidate every entry owned by the cache demo endpoint."""
    await FastAPICache.clear(namespace="demo")
