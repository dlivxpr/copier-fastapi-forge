"""FastAPI dependencies shared by business routes."""

import secrets
from typing import Annotated

from fastapi import Depends
from fastapi.security import APIKeyHeader
[% if database == "postgresql" %][% if orm_type == "sqlalchemy" %]from sqlalchemy.ext.asyncio import AsyncSession
[% else %]from sqlmodel.ext.asyncio.session import AsyncSession
[% endif %][% endif %]
from app.core.config import settings
from app.core.exceptions import APIKeyMissingError, InvalidAPIKeyError
[% if database == "postgresql" %]from app.db.session import get_db_session
[% endif %]
api_key_header = APIKeyHeader(name=settings.API_KEY_HEADER, auto_error=False)


async def verify_api_key(
    api_key: Annotated[str | None, Depends(api_key_header)],
) -> str:
    """Verify the deployment API key using constant-time comparison."""
    if api_key is None:
        raise APIKeyMissingError()
    if not secrets.compare_digest(api_key, settings.API_KEY):
        raise InvalidAPIKeyError()
    return api_key


ValidAPIKey = Annotated[str, Depends(verify_api_key)]
RequireApiKey = Depends(verify_api_key)
[% if database == "postgresql" %]
DBSession = Annotated[AsyncSession, Depends(get_db_session, scope="function")]
[% endif -%]
