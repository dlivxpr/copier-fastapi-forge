from __future__ import annotations

[% if database == "postgresql" %]from collections.abc import AsyncIterator
[% endif %]from typing import Annotated

from fastapi import Depends, Header
[% if database == "postgresql" %][% if orm == "sqlalchemy" %]from sqlalchemy.ext.asyncio import AsyncSession
[% else %]from sqlmodel.ext.asyncio.session import AsyncSession
[% endif %][% endif %]
[% if agent_capability == "pydantic-ai" %]from app.agents.assistant import (
    AgentDependencies,
    AssistantAgent,
    create_configured_agent,
)
[% endif %]from app.core.config import Settings
from app.core.exceptions import UnauthorizedError
from app.core.pagination import PaginationParams
[% if database == "postgresql" %]from app.db.session import database
from app.repositories.resource import ResourceRepository
[% endif %][% if agent_capability == "pydantic-ai" %]from app.services.agent import AgentInvocationService
[% endif %][% if database == "postgresql" %]from app.services.resource import ResourceService
[% endif %]

def _get_settings() -> Settings:
    return Settings()


SettingsDep = Annotated[Settings, Depends(_get_settings)]
PaginationDep = Annotated[PaginationParams, Depends()]


def _verify_api_key(
    settings: SettingsDep,
    x_api_key: Annotated[str | None, Header(alias="X-API-Key")] = None,
) -> None:
    if x_api_key != settings.api_key:
        raise UnauthorizedError("Invalid or missing API key")


RequireApiKey = Depends(_verify_api_key)
[% if agent_capability == "pydantic-ai" %]

def get_agent(settings: SettingsDep) -> AssistantAgent:
    return create_configured_agent(settings)


AgentDep = Annotated[AssistantAgent, Depends(get_agent)]


def get_agent_dependencies(settings: SettingsDep) -> AgentDependencies:
    return AgentDependencies(model_name=settings.llm_model)


AgentDependenciesDep = Annotated[AgentDependencies, Depends(get_agent_dependencies)]


def get_agent_service(
    agent: AgentDep,
    dependencies: AgentDependenciesDep,
) -> AgentInvocationService:
    return AgentInvocationService(agent, dependencies)
[% endif %][% if database == "postgresql" %]

async def get_session() -> AsyncIterator[AsyncSession]:
    async with database.session() as session:
        yield session


SessionDep = Annotated[AsyncSession, Depends(get_session)]


def get_resource_service(session: SessionDep) -> ResourceService:
    return ResourceService(ResourceRepository(session))


ResourceServiceDep = Annotated[ResourceService, Depends(get_resource_service)]
[% endif -%]
