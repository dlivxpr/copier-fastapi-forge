{
  "agent_request": {
    "additionalProperties": false,
    "properties": {
      "input": {
        "minLength": 1,
        "title": "Input",
        "type": "string"
      }
    },
    "required": [
      "input"
    ],
    "title": "AgentInvocationRequest",
    "type": "object"
  },
  "agent_stream_content": {
    "text/event-stream": {
      "itemSchema": {
        "properties": {
          "data": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "retry": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "type": "object"
      }
    }
  },
  "forbidden_schemas": [
    "ErrorResponse"
  ],
  "operations": [
    {
      "method": "get",
      "path": "/health",
      "responses": [
        "200"
      ],
      "security": "public"
    },
    {
      "method": "get",
      "path": "/health/live",
      "responses": [
        "200"
      ],
      "security": "public"
    },
    {
      "method": "get",
      "path": "/health/ready",
      "responses": [
        "200"
      ],
      "security": "public"
    },
    {
      "method": "post",
      "path": "/agent/run",
      "responses": [
        "200",
        "422"
      ],
      "security": "api_key"
    },
    {
      "method": "post",
      "path": "/agent/stream",
      "responses": [
        "200",
        "422"
      ],
      "security": "api_key"
    },
    {
      "method": "post",
      "path": "/api/v1/items",
      "responses": [
        "201",
        "422"
      ],
      "security": "api_key"
    },
    {
      "method": "delete",
      "path": "/api/v1/items/{item_id}",
      "responses": [
        "204",
        "422"
      ],
      "security": "api_key"
    },
    {
      "method": "get",
      "path": "/api/v1/items/{item_id}",
      "responses": [
        "200",
        "422"
      ],
      "security": "api_key"
    },
    {
      "method": "patch",
      "path": "/api/v1/items/{item_id}",
      "responses": [
        "200",
        "422"
      ],
      "security": "api_key"
    }
  ],
  "required_schemas": [
    "ItemRead"
  ],
  "security_schemes": {
    "APIKeyHeader": {
      "in": "header",
      "name": "X-API-Key",
      "type": "apiKey"
    }
  }
}
